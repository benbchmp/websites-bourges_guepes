---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { entreprise } from "../data/site";

// Métas volontairement minimales : le SEO se traite dans une passe dédiée,
// après validation de la maquette (cf. CLAUDE.md §7).
const titre = `${entreprise.nom} — ${entreprise.metier} à ${entreprise.ville}`;
const description = `Destruction de nids de guêpes et de frelons à ${entreprise.ville} et dans tout le ${entreprise.departement}. 7 j/7 de 8h à 21h, agréé Certibiocide, devis gratuit par téléphone.`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{titre}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f5f5" />

    <!-- Les polices sont auto-hébergées : on précharge les deux graisses
         utilisées au premier écran pour éviter le clignotement du titre. -->
    <link rel="preload" href="/fonts/anton-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/switzer-400.woff2" as="font" type="font/woff2" crossorigin />
  </head>

  <body>
    <a
      href="#contenu"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-100 focus:rounded-lg focus:bg-noir focus:px-5 focus:py-3 focus:text-white"
    >
      Aller au contenu
    </a>

    <Nav />
    <main id="contenu">
      <slot />
    </main>
    <Footer />

    <script>
      // Apparition douce des blocs .reveal au défilement.
      const blocs = document.querySelectorAll<HTMLElement>(".reveal");
      const animationsReduites = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (animationsReduites) {
        blocs.forEach((el) => el.classList.add("is-visible"));
      } else {
        const observateur = new IntersectionObserver(
          (entrees) => {
            entrees.forEach((entree) => {
              if (entree.isIntersecting) {
                entree.target.classList.add("is-visible");
                observateur.unobserve(entree.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.06 }
        );
        blocs.forEach((el) => observateur.observe(el));
      }
    </script>
  </body>
</html>
