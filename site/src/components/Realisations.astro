---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import volet from "../assets/volet.jpg";
import arbre from "../assets/arbre.jpg";
import charpente from "../assets/charpente.jpg";
import { realisations } from "../data/site";

const images: Record<string, ImageMetadata> = { volet, arbre, charpente };
---

<section id="realisations" class="bg-white py-20 sm:py-28 lg:py-32">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="reveal flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="overline">Réalisations</p>
        <span class="rule-guepe my-5"></span>
        <h2 class="max-w-[16ch] text-[clamp(1.9rem,4.2vw,3.1rem)]">
          Trois nids, trois situations
        </h2>
      </div>

      <div class="flex shrink-0 items-center gap-3">
        <button
          type="button"
          id="realisations-prec"
          aria-label="Réalisation précédente"
          class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-noir/15 text-noir transition-colors hover:border-noir hover:bg-noir hover:text-jaune disabled:pointer-events-none disabled:opacity-30"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 18l-6-6 6-6"></path>
          </svg>
        </button>
        <button
          type="button"
          id="realisations-suiv"
          aria-label="Réalisation suivante"
          class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-noir/15 text-noir transition-colors hover:border-noir hover:bg-noir hover:text-jaune disabled:pointer-events-none disabled:opacity-30"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 6l6 6-6 6"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Défilement natif avec accrochage : la molette, le doigt et les flèches
         agissent sur le même mécanisme, et ça reste utilisable sans JavaScript. -->
    <div
      id="realisations-piste"
      class="reveal mt-10 flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-smooth pb-4 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      tabindex="0"
      aria-label="Carrousel des réalisations"
    >
      {
        realisations.map((realisation, index) => (
          <article
            class="flex w-[min(100%,68rem)] shrink-0 snap-start flex-col overflow-hidden rounded-3xl border border-noir/10 bg-clair sm:flex-row"
            data-index={index}
          >
            <div class="relative sm:w-[38%] sm:shrink-0">
              <Image
                src={images[realisation.image]!}
                alt={`${realisation.titre} — ${realisation.lieu}`}
                widths={[420, 640]}
                sizes="(min-width: 640px) 38vw, 100vw"
                class="h-56 w-full object-cover sm:h-full"
              />
              <span class="absolute left-4 top-4 rounded-full bg-rouge px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">
                {realisation.chapo}
              </span>
            </div>

            <div class="flex flex-1 flex-col justify-center p-7 sm:p-10">
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-rouge-fonce">
                {realisation.lieu}
              </p>
              <h3 class="mt-3 text-[clamp(1.4rem,2.6vw,2rem)]">{realisation.titre}</h3>
              <p class="mt-4 max-w-[62ch] text-noir/70">{realisation.texte}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-2 flex items-center justify-center gap-2" id="realisations-points" role="tablist" aria-label="Choisir une réalisation">
      {
        realisations.map((realisation, index) => (
          <button
            type="button"
            role="tab"
            data-point={index}
            aria-label={`Voir : ${realisation.titre}`}
            aria-selected={index === 0 ? "true" : "false"}
            class="h-2 rounded-full bg-noir/15 transition-all aria-selected:w-8 aria-selected:bg-noir w-2"
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  const piste = document.getElementById("realisations-piste");
  const precedent = document.getElementById("realisations-prec") as HTMLButtonElement | null;
  const suivant = document.getElementById("realisations-suiv") as HTMLButtonElement | null;
  const points = Array.from(
    document.querySelectorAll<HTMLButtonElement>("#realisations-points [data-point]")
  );

  if (piste && precedent && suivant) {
    const cartes = Array.from(piste.querySelectorAll<HTMLElement>("article"));

    // Index de la carte la plus proche du bord gauche de la zone visible.
    function indexCourant(): number {
      let meilleur = 0;
      let ecartMin = Infinity;
      cartes.forEach((carte, i) => {
        const ecart = Math.abs(carte.offsetLeft - piste!.scrollLeft);
        if (ecart < ecartMin) {
          ecartMin = ecart;
          meilleur = i;
        }
      });
      return meilleur;
    }

    function allerA(index: number) {
      const cible = cartes[Math.max(0, Math.min(index, cartes.length - 1))];
      if (cible) piste!.scrollTo({ left: cible.offsetLeft, behavior: "smooth" });
    }

    function rafraichir() {
      const index = indexCourant();
      precedent!.disabled = index === 0;
      suivant!.disabled = index === cartes.length - 1;
      points.forEach((point, i) =>
        point.setAttribute("aria-selected", String(i === index))
      );
    }

    precedent.addEventListener("click", () => allerA(indexCourant() - 1));
    suivant.addEventListener("click", () => allerA(indexCourant() + 1));
    points.forEach((point, i) => point.addEventListener("click", () => allerA(i)));

    // Les flèches du clavier pilotent le carrousel quand il a le focus.
    piste.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") { e.preventDefault(); allerA(indexCourant() + 1); }
      if (e.key === "ArrowLeft") { e.preventDefault(); allerA(indexCourant() - 1); }
    });

    let attente = 0;
    piste.addEventListener("scroll", () => {
      window.clearTimeout(attente);
      attente = window.setTimeout(rafraichir, 90);
    });
    window.addEventListener("resize", rafraichir);
    rafraichir();
  }
</script>
